{
    "name": "binary-cats/shard-collections",
    "description": "Enhance your Laravel collections with shard()",
    "keywords": [
        "Binary Cats",
        "laravel",
        "collection",
        "shard"
    ],
    "homepage": "https://github.com/binary-cats/shard-collections",
    "license": "MIT",
    "authors": [
        {
            "name": "Cyrill N Kalita",
            "email": "cyrill.kalita@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.1.1",
        "larastan/larastan": "^2.9|^3.0",
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0|^5.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0|^4.0|^5.0",
        "phpstan/extension-installer": "^1.3",
        "phpstan/phpstan-deprecation-rules": "^1.1|^2.0",
        "phpstan/phpstan-phpunit": "^1.3|^2.0"
    },
    "autoload": {
        "psr-4": {
            "BinaryCats\\ShardCollections\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BinaryCats\\ShardCollections\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "XDEBUG_MODE=coverage vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "suggest": {
        "binary-cats/laravel-rbac": "Laravel enum-backed RBAC extension of spatie/laravel-permission",
        "binary-cats/laravel-mailgun-webhooks": "Handle Mailgun webhooks in your Laravel application"
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.x-dev"
        },
        "laravel": {
            "providers": [
                "BinaryCats\\ShardCollections\\ShardCollectionServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
